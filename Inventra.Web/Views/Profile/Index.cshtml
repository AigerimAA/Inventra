@using Inventra.Application.DTOs
@using Inventra.Web.Models
@model ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<style>
.inv-card { border-radius: 12px; overflow: hidden; border: 0.5px solid var(--bs-border-color); margin-bottom: 20px; }
.inv-card-header { background: #0097a7; padding: 14px 20px; display: flex; justify-content: space-between; align-items: center; }
.inv-card-header span { color: white; font-size: 15px; font-weight: 500; }
.inv-table { width: 100%; border-collapse: collapse; }
.inv-table thead tr { border-bottom: 0.5px solid var(--bs-border-color); }
.inv-table thead th { padding: 10px 16px; font-size: 12px; font-weight: 500; color: var(--bs-secondary-color); text-transform: uppercase; letter-spacing: 0.05em; }
.inv-table tbody tr { border-bottom: 0.5px solid var(--bs-border-color); transition: background 0.15s; cursor: pointer; }
.inv-table tbody tr:hover { background: rgba(0,151,167,0.06); }
.inv-table tbody tr:last-child { border-bottom: none; }
.inv-table tbody td { padding: 12px 16px; font-size: 14px; }
.inv-badge { display: inline-block; background: rgba(0,151,167,0.12); color: #0097a7; font-size: 12px; padding: 2px 8px; border-radius: 20px; font-weight: 500; }
.inv-count { font-weight: 500; color: #0097a7; }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">@L["MyProfile"]</h2>
        <span class="text-muted">
            @User.Identity?.Name · 
            @User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
        </span>
    </div>
</div>

<div class="inv-card">
    <div class="inv-card-header">
        <span>@L["MyInventories"] (@Model.OwnedInventories.Count())</span>
        <a asp-controller="Inventory" asp-action="Create"
           class="profile-btn"
           style="background:white; color:#0097a7; padding:6px 16px; border-radius:6px; font-size:13px; font-weight:500; text-decoration:none;">
            @L["NewInventory"]
        </a>
    </div>
    <table class="inv-table profile-table">
        <thead>
            <tr>
                <th>@L["Title"]</th>
                <th>@L["CategoryLabel"]</th>
                <th class="text-end">@L["Items"]</th>
                <th>@L["Access"]</th>
                <th>@L["Tags"]</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.OwnedInventories.Any())
            {
                <tr><td colspan="5" class="text-center" style="padding:24px; color:var(--bs-secondary-color);">@L["NoInventoriesYet"]</td></tr>
            }
            else
            {
                @foreach (var inv in Model.OwnedInventories)
                {
                    <tr onclick="window.location='/Inventory/Details/@inv.Id'">
                        <td style="font-weight:500;">@inv.Title</td>
                        <td><span class="inv-badge">@inv.CategoryName</span></td>
                        <td class="text-end inv-count">@inv.ItemsCount</td>
                        <td><span class="inv-badge">@(inv.IsPublic ? @L["Public"] : @L["Private"])</span></td>
                        <td>@foreach (var tag in inv.Tags) {
                            <span class="inv-badge me-1">@tag</span>
                        }</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<div class="inv-card">
    <div class="inv-card-header">
        <span>@L["InventoriesWithAccess"] (@Model.AccessibleInventories.Count())</span>
    </div>
    <table class="inv-table profile-table">
        <thead>
            <tr>
                <th>@L["Title"]</th>
                <th>@L["CategoryLabel"]</th>
                <th>@L["Creator"]</th>
                <th class="text-end">@L["Items"]</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.AccessibleInventories.Any())
            {
                <tr><td colspan="4" class="text-center" style="padding:24px; color:var(--bs-secondary-color);">@L["NoAccessInventories"]</td></tr>
            }
            else
            {
                @foreach (var inv in Model.AccessibleInventories)
                {
                    <tr onclick="window.location='/Inventory/Details/@inv.Id'">
                        <td style="font-weight:500;">@inv.Title</td>
                        <td><span class="inv-badge">@inv.CategoryName</span></td>
                        <td style="color:var(--bs-secondary-color);">@inv.OwnerName</td>
                        <td class="text-end inv-count">@inv.ItemsCount</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
<div class="inv-card">
    <div class="inv-card-header">
        <span>Salesforce CRM</span>
    </div>
    <div style="padding:20px;">
        @if (TempData["SalesforceSuccess"] != null)
        {
            <div class="alert alert-success">@TempData["SalesforceSuccess"]</div>
        }
        @if (TempData["SalesforceError"] != null)
        {
            <div class="alert alert-danger">@TempData["SalesforceError"]</div>
        }
        <p style="color:var(--bs-body-color); margin-bottom:16px;">
            @L["SalesforceDescription"]
        </p>
        <button type="button" class="btn btn-primary"
                data-bs-toggle="modal" data-bs-target="#salesforceModal">
            @L["ConnectToSalesforce"]
        </button>
    </div>
</div>

<div class="modal fade" id="salesforceModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background:#0097a7;">
                <h5 class="modal-title" style="color:white;">@L["SalesforceTitle"]</h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>
            <form asp-controller="Salesforce" asp-action="CreateContact" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">@L["FirstName"]</label>
                        <input type="text" name="firstName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">@L["LastName"]</label>
                        <input type="text" name="lastName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">@L["Phone"]</label>
                        <input type="tel" name="phone" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">@L["Company"]</label>
                        <input type="text" name="company" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">@L["Cancel"]</button>
                    <button type="submit" class="btn btn-primary">@L["CreateInSalesforce"]</button>
                </div>
            </form>
        </div>
    </div>
</div>