@using Inventra.Application.DTOs
@using Inventra.Web.Models
@model HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<div style="background:#0097a7; padding:70px 48px; margin:-16px -12px 0; text-align:center;">
    <div style="max-width:700px; margin:0 auto;">
        <img src="~/images/logo-white.svg" alt="Inventra" height="48" style="margin-bottom:24px;" />
        <h1 id="heroText" style="color:white; font-size:2rem; font-weight:500; margin:0 0 20px; min-height:3em;"></h1>
        @if (!User.Identity?.IsAuthenticated ?? true)
        {
            <a asp-controller="Account" asp-action="Register"
                   class="hero-btn"
                   style="display:inline-block; background:white; color:#0097a7; padding:12px 32px; border-radius:8px; font-weight:500; text-decoration:none; font-size:15px; transition:all 0.2s;">
                @L["GetStarted"]
            </a>
        }
        else
        {
            <a asp-controller="Inventory" asp-action="Create"
                   class="hero-btn"
                   style="display:inline-block; background:white; color:#0097a7; padding:12px 32px; border-radius:8px; font-weight:500; text-decoration:none; font-size:15px; transition:all 0.2s;">
                @L["NewInventory"]
            </a>
        }
    </div>
</div>

<style>
    .hero-btn {
        background: white !important;
    }
    .hero-btn:hover {
        background: white !important;
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(0,0,0,0.2);
        opacity: 0.95;
    }
</style>

<span id="heroTagline" style="display:none;">@L["Tagline"]</span>

<script>
    const heroText = document.getElementById('heroTagline').textContent;
    let i = 0;
    const el = document.getElementById('heroText');
    function type() {
        if (i < heroText.length) {
            el.textContent += heroText[i];
            i++;
            setTimeout(type, 50);
        }
    }
    type();
</script>


<div class="row mt-4">
    <div class="col-md-8">
        <h4>@L["LatestInventories"]</h4>
        <table class="table table-hover table-sm">
            <thead>
                <tr>
                    <th>@L["Title"]</th>
                    <th>@L["CategoryLabel"]</th>
                    <th>@L["Creator"]</th>
                    <th class="text-end">@L["Items"]</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.LatestInventories.Any())
                {
                    <tr><td colspan="4" class="text-muted text-center">No inventories yet. Be the first to create one!</td></tr>
                }
                else
                {
                    @foreach (var inv in Model.LatestInventories)
                    {
                        <tr style="cursor:pointer" onclick="window.location='/Inventory/Details/@inv.Id'">
                            <td>@inv.Title</td>
                            <td>@inv.CategoryName</td>
                            <td>@inv.OwnerName</td>
                            <td class="text-end">@inv.ItemsCount</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="col-md-4">
        <h4>@L["Top5Popular"]</h4>
        <table class="table table-hover table-sm">
            <thead>
                <tr>
                    <th>@L["Title"]</th>
                    <th class="text-end">@L["Items"]</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.PopularInventories.Any())
                {
                    <tr><td colspan="2" class="text-muted text-center">No data yet.</td></tr>
                }
                else
                {
                    @foreach (var inv in Model.PopularInventories)
                    {
                        <tr style="cursor:pointer" onclick="window.location='/Inventory/Details/@inv.Id'">
                            <td>@inv.Title</td>
                            <td class="text-end">@inv.ItemsCount</td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        <h4 class="mt-4">@L["Tags"]</h4>
        <div class="d-flex flex-wrap gap-2">
            @if (!Model.TagCloud.Any())
            {
                <span class="text-muted">@L["NoTagsYet"]</span>
            }
            else
            {
                var maxCount = Math.Max(1, Model.TagCloud.Max(t => t.Count));
                @foreach (var tag in Model.TagCloud)
                {
                    var normalized = Math.Sqrt((double)tag.Count / maxCount);
                    var fontSize = (0.8 + normalized * 1.2).ToString("F1", System.Globalization.CultureInfo.InvariantCulture);
                    <a asp-controller="Search" asp-action="Index" asp-route-q="@tag.Name"
                           class="badge bg-secondary text-decoration-none"
                           style="font-size: @(fontSize + "rem")"
                           title="@tag.Count inventories">
                        @tag.Name
                    </a>
                }
            }
        </div>
    </div>
</div>
